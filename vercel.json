<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BloxKeys Clone | Premium Access</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <div class="logo">BloxKeys</div>
      <div class="nav-links">
        <a href="/login" class="btn-login">Customer Login</a>
        <a href="/products" class="btn-products">Products</a>
      </div>
    </div>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>BloxKeys<br><span class="hero-subtitle">Premium Roblox Keys</span></h1>
        <p>Your Gateway To Premium Roblox Keys! Instantly delivered digital license keys that unlocks premium software features.</p>
        <div class="hero-buttons">
          <a href="/products" class="btn-primary">Get Started Now</a>
          <a href="/products" class="btn-secondary">All Products</a>
        </div>
        <div class="trust-indicator">
          <div class="stars">⭐⭐⭐⭐⭐</div>
          <div class="trust-text">Trusted by 10,000+ customers worldwide</div>
        </div>
      </div>
      <div class="terminal-widget">
        <div class="terminal-header">
          <div class="terminal-buttons">
            <span class="terminal-btn red"></span>
            <span class="terminal-btn yellow"></span>
            <span class="terminal-btn green"></span>
          </div>
          <div class="terminal-title">Terminal</div>
        </div>
        <div class="terminal-body">
          <div class="terminal-line">$ platform status --verbose</div>
          <div class="terminal-line terminal-output">Status: All systems operational ✓</div>
        </div>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <h2>Popular Products</h2>
      <p class="section-subtitle">Trusted products crafted to deliver reliability, speed, and seamless performance.</p>
      <div class="feature-grid">
        <div class="feature-card">
          <h3>Free Access</h3>
          <p>Access free products instantly without any payment required</p>
        </div>
        <div class="feature-card">
          <h3>Premium Tier</h3>
          <p>Unlock exclusive premium content with verified access</p>
        </div>
        <div class="feature-card">
          <h3>Instant Delivery</h3>
          <p>Get your products delivered immediately after verification</p>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p>&copy; 2025 BloxKeys Clone. All Rights Reserved.</p>
    </div>
  </footer>
</body>
</html>
